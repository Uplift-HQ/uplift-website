{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/nova", "destination": "/index.html" },
    { "source": "/demo", "destination": "/index.html" },
    { "source": "/pricing", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/platform", "destination": "/index.html" },
    { "source": "/industries", "destination": "/index.html" },
    { "source": "/industries/:path*", "destination": "/index.html" }
  ]
}
